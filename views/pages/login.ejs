<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login</title>
    <link rel="stylesheet" href="/css/generic.css">
    <link rel="stylesheet" href="/css/login.css">
</head>

<body>

    <div class="login-container">
        <div class="login-box">


            <div id="emailForm" class="form-section">
                <h1>Login or Create Account</h1>
                <form id="emailFormElement">
                    <div class="form-group">
                        <input type="email" id="email" name="email" placeholder=" " required>
                        <label for="email">Email Address</label>
                    </div>
                    <p class="form-message" id="emailMessage"></p>
                    <button type="submit" class="btn btn-primary">Next</button>
                </form>

            </div>

            <div id="otpForm" class="form-section hidden">
                <h1>Verify Email</h1>
                <form id="otpFormElement">
                    <p class="info-text">Enter the 6-digit OTP sent to <strong id="displayEmail"></strong></p>

                    <div class="form-group">
                        <input type="text" id="otp" name="otp" placeholder=" " maxlength="6" pattern="[0-9]{6}"
                            required>
                        <label for="otp">Enter code</label>
                    </div>

                    <div class="button-group">
                        <!-- <button type="button" class="btn btn-secondary" id="backBtn">Back</button> -->
                        <button type="submit" class="btn btn-primary">Verify</button>
                    </div>
                </form>

              
            </div>
        </div>
    </div>


    <script src="/js/login.js"></script>
</body>

</html>